# =====================================================
# COCO CLAW Web 前端环境配置
# 复制此文件为 .env.local 后修改对应值
# =====================================================

# API 基础地址
NUXT_PUBLIC_API_BASE=http://localhost:8080/api

# 是否启用 Mock 模式 (true/false)
# 开发环境建议 true，生产环境必须 false
NUXT_PUBLIC_MOCK_MODE=true

# WebSocket 地址 (可选)
# NUXT_PUBLIC_WS_URL=ws://localhost:8080
